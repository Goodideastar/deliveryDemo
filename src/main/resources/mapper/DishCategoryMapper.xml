<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.warehouse.deliverydemo.mapper.DishCategoryMapper">
    <select id="findByMerchantId" resultType="com.warehouse.deliverydemo.entity.DishCategory">
        SELECT * FROM dish_category WHERE merchant_id = #{merchantId} ORDER BY sort ASC
    </select>
    
    <select id="findById" resultType="com.warehouse.deliverydemo.entity.DishCategory">
        SELECT * FROM dish_category WHERE id = #{id}
    </select>
    
    <insert id="insert" parameterType="com.warehouse.deliverydemo.entity.DishCategory">
        INSERT INTO dish_category (merchant_id, name, sort, created_at, updated_at)
        VALUES (#{merchantId}, #{name}, #{sort}, NOW(), NOW())
    </insert>
    
    <update id="update" parameterType="com.warehouse.deliverydemo.entity.DishCategory">
        UPDATE dish_category SET
        name = #{name},
        sort = #{sort},
        updated_at = NOW()
        WHERE id = #{id}
    </update>
    
    <delete id="delete">
        DELETE FROM dish_category WHERE id = #{id}
    </delete>
</mapper>