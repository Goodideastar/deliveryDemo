<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.warehouse.deliverydemo.mapper.UserMapper">
    <select id="findByPhone" resultType="com.warehouse.deliverydemo.entity.User">
        SELECT * FROM user WHERE phone = #{phone}
    </select>
    
    <select id="findByEmail" resultType="com.warehouse.deliverydemo.entity.User">
        SELECT * FROM user WHERE email = #{email}
    </select>
    
    <select id="findByUsername" resultType="com.warehouse.deliverydemo.entity.User">
        SELECT * FROM user WHERE username = #{username}
    </select>
    
    <insert id="insert" parameterType="com.warehouse.deliverydemo.entity.User">
        INSERT INTO user (username, password, phone, email, nickname, avatar, role, status, created_at, updated_at)
        VALUES (#{username}, #{password}, #{phone}, #{email}, #{nickname}, #{avatar}, #{role}, #{status}, NOW(), NOW())
    </insert>
    
    <select id="findById" resultType="com.warehouse.deliverydemo.entity.User">
        SELECT * FROM user WHERE id = #{id}
    </select>
    
    <update id="update" parameterType="com.warehouse.deliverydemo.entity.User">
        UPDATE user SET
        username = #{username},
        password = #{password},
        phone = #{phone},
        email = #{email},
        nickname = #{nickname},
        avatar = #{avatar},
        role = #{role},
        status = #{status},
        updated_at = NOW()
        WHERE id = #{id}
    </update>
</mapper>